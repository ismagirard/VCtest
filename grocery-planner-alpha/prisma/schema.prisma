generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String   @id @default(cuid())
  email                 String   @unique
  name                  String?
  password              String
  householdSize         Int      @default(1)
  mealsPerDay           Int      @default(3)
  cookingTimePreference String   @default("moderate")
  location              String?
  preferredStores       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
